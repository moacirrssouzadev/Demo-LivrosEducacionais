@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<section class="empty-state">
    <div>
        <span class="empty-icon mx-auto" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                <path d="M12 9v4" />
                <path d="M12 17h.01" />
            </svg>
        </span>
        <h1 class="h4">Não foi possível concluir a solicitação</h1>
        <p class="text-muted mb-4">Tente novamente ou retorne ao acervo.</p>

        @if (Model.ShowRequestId)
        {
            <p class="field-hint">Código da solicitação: <code>@Model.RequestId</code></p>
        }

        <a asp-controller="Books" asp-action="Index" class="btn btn-primary">Voltar ao acervo</a>
    </div>
</section>
