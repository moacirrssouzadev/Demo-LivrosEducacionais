@model UpdateBookViewModel

@{
    ViewData["Title"] = "Editar Livro";
}

<div class="page-header">
    <div>
        <p class="page-kicker">Edição</p>
        <h1 class="page-title">Editar livro</h1>
        <p class="page-subtitle">Atualize os dados do material e, se necessário, substitua a capa exibida no acervo.</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Voltar</a>
</div>

<form asp-action="Edit" enctype="multipart/form-data" class="form-shell">
    <section class="card form-panel">
        <div asp-validation-summary="All" class="text-danger mb-4"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Título <span class="text-danger">*</span></label>
            <input asp-for="Title" class="form-control" placeholder="Ex.: Matemática em contexto">
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Author" class="form-label">Autor <span class="text-danger">*</span></label>
                <input asp-for="Author" class="form-control" placeholder="Nome do autor">
                <span asp-validation-for="Author" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Subject" class="form-label">Disciplina <span class="text-danger">*</span></label>
                <input asp-for="Subject" class="form-control" placeholder="Ex.: Ciências">
                <span asp-validation-for="Subject" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-3">
            <label asp-for="Description" class="form-label">Descrição</label>
            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Resumo, série indicada ou observações do material"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
            <button type="submit" class="btn btn-primary d-inline-flex align-items-center justify-content-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                    <path d="M17 21v-8H7v8" />
                    <path d="M7 3v5h8" />
                </svg>
                Salvar alterações
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </section>

    <aside class="card form-panel">
        <h2 class="h5 fw-bold mb-2">Capa do livro</h2>
        <p class="field-hint mb-3">Envie uma nova imagem para substituir a capa atual.</p>
        <label asp-for="CoverImage" class="form-label">Arquivo da capa</label>
        <input asp-for="CoverImage" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp" id="coverImageInput">
        <div class="cover-preview-frame mt-3">
            @if (!string.IsNullOrEmpty(Model.CurrentCoverUrl))
            {
                <img id="coverPreview" src="@Model.CurrentCoverUrl" alt="Capa atual">
                <div id="coverPlaceholder" class="d-none"></div>
            }
            else
            {
                <div id="coverPlaceholder" class="text-center p-4">
                    <span class="empty-icon mx-auto mb-3" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                        </svg>
                    </span>
                    <p class="text-muted mb-0">Sem capa cadastrada</p>
                </div>
                <img id="coverPreview" src="" alt="Prévia da nova capa" class="d-none">
            }
        </div>
    </aside>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const coverInput = document.getElementById('coverImageInput');
        const preview = document.getElementById('coverPreview');
        const placeholder = document.getElementById('coverPlaceholder');

        coverInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    preview.src = event.target.result;
                    preview.classList.remove('d-none');
                    placeholder.classList.add('d-none');
                };
                reader.readAsDataURL(file);
            } else if (!preview.getAttribute('src')) {
                preview.classList.add('d-none');
                placeholder.classList.remove('d-none');
            }
        });
    </script>
}
