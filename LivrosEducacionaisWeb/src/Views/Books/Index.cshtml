@model BookListViewModel

@{
    ViewData["Title"] = "Acervo";
}

<section class="hero-panel">
    <div class="hero-content page-header mb-0">
        <div>
            <p class="page-kicker">Acervo digital</p>
            <h1 class="page-title">Livros Educacionais</h1>
            <p class="page-subtitle">Organize títulos, autores, disciplinas, capas e versões dos materiais didáticos em um fluxo simples e visual.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-inline-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5v14" />
                <path d="M5 12h14" />
            </svg>
            Novo livro
        </a>
    </div>
</section>

<section class="stats-row" aria-label="Resumo do acervo">
    <div class="metric-card">
        <span class="metric-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
        </span>
        <div>
            <p class="metric-value">@Model.TotalCount</p>
            <p class="metric-label">livros cadastrados</p>
        </div>
    </div>

    <div class="metric-card">
        <span class="metric-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v18" />
                <path d="m8 7 4-4 4 4" />
                <path d="m8 17 4 4 4-4" />
            </svg>
        </span>
        <div>
            <p class="metric-value">@Model.Books.Count</p>
            <p class="metric-label">itens nesta página</p>
        </div>
    </div>

    <div class="metric-card">
        <span class="metric-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3h7v7H3z" />
                <path d="M14 3h7v7h-7z" />
                <path d="M14 14h7v7h-7z" />
                <path d="M3 14h7v7H3z" />
            </svg>
        </span>
        <div>
            <p class="metric-value">@Model.PageNumber/@(Model.TotalPages == 0 ? 1 : Model.TotalPages)</p>
            <p class="metric-label">página atual</p>
        </div>
    </div>
</section>

@if (Model.Books.Any())
{
    <section class="book-grid" aria-label="Lista de livros">
        @foreach (var book in Model.Books)
        {
            <article class="card book-card">
                @if (!string.IsNullOrEmpty(book.CoverUrl))
                {
                    <img src="@book.CoverUrl" class="book-cover" alt="Capa de @book.Title">
                }
                else
                {
                    <div class="cover-placeholder" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                        </svg>
                    </div>
                }
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                        <h2 class="h5 book-title mb-0">@book.Title</h2>
                        <span class="badge badge-soft">v@book.Version</span>
                    </div>
                    <div class="book-meta mb-4">
                        <span>Autor: @book.Author</span>
                        <span>Disciplina: @book.Subject</span>
                    </div>
                    <div class="d-flex gap-2 mt-auto">
                        <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-primary btn-sm flex-grow-1">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-outline-secondary btn-sm">Editar</a>
                    </div>
                </div>
            </article>
        }
    </section>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Paginação do acervo">
            <ul class="pagination justify-content-center flex-wrap">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)">Anterior</a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                    </li>
                }

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)">Próximo</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <section class="empty-state">
        <div>
            <span class="empty-icon mx-auto" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
            </span>
            <h2 class="h4">Nenhum livro cadastrado</h2>
            <p class="text-muted mb-4">Crie o primeiro item do acervo para começar a acompanhar capas, disciplinas e versões.</p>
            <a asp-action="Create" class="btn btn-primary">Criar livro</a>
        </div>
    </section>
}
